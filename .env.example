# ============================================================
# .env.example — Скопируйте в .env и заполните значения
# ============================================================

# Backend variables
# Токен вашего бота (получить у @BotFather)
BOT_TOKEN=1234567890:ABCdefGhIJKlmNOpqRSTuvWXyz

# Ваш Telegram User ID (получить у @userinfobot)
ADMIN_ID=

# Секретный ключ для HMAC аутентификации (генерируйте случайную строку)
ADMIN_SECRET_KEY=

# Ваш Telegram Username (для редиректа в личку)
ADMIN_USERNAME=@SotkaLashes

# Путь к файлу БД (по умолчанию в корне проекта)
DB_PATH=lash_bot.db

# Production URLs (заполнить при деплое)
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-backend.onrender.com
WS_URL=wss://your-backend.onrender.com/ws

# Ссылки на социальные сети
INSTAGRAM_LINK=https://instagram.com/yourusername

# Frontend variables (Vite)
# Backend API URL
VITE_BACKEND_URL=http://localhost:8000

# Admin credentials (для admin panel)
VITE_ADMIN_ID=
VITE_ADMIN_SECRET_KEY=

# Telegram Bot Token (для интеграции)
VITE_BOT_TOKEN=

# Ссылка на пост с ценами
VITE_PRICES_POST_LINK=https://t.me/your_channel/123

# Ссылка на Instagram
VITE_INSTAGRAM_LINK=https://instagram.com/yourusername
