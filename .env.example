# ============================================================
# .env.example — Скопируйте в .env и заполните значения
# ============================================================

# Токен вашего бота (получить у @BotFather)
BOT_TOKEN=1234567890:ABCdefGhIJKlmNOpqRSTuvWXyz

# Ваш Telegram User ID (получить у @userinfobot)
ADMIN_ID=1834686956

# Ваш Telegram Username (для редиректа в личку)
ADMIN_USERNAME=@SotkaLashes

# Production URLs (заполнить при деплое)
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-backend.onrender.com

# Ссылки на социальные сети
INSTAGRAM_LINK=https://instagram.com/yourusername

# Путь к файлу БД (по умолчанию в корне проекта)
DB_PATH=lash_bot.db
